# Backend Environment Configuration
# Copy this file to .env and update with your settings

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Model Storage
MODEL_DIR=models
MODEL_NAME=trained_model.pkl

# CORS (for production, specify actual frontend URL)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
