# Backend Environment Configuration
# Copy this file to .env and update with your settings

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Model Storage
MODEL_DIR=models
MODEL_NAME=trained_model.pkl

# CORS (for production, specify actual frontend URL)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# === NEW: QuickBooks OAuth (add to .env file, NOT in .env.example) ===
# QB_CLIENT_ID=your_client_id_from_intuit_developer
# QB_CLIENT_SECRET=your_client_secret_from_intuit_developer
# QB_REDIRECT_URI=http://localhost:8000/api/quickbooks/callback
# QB_ENVIRONMENT=sandbox  # Change to 'production' when ready
# QB_SESSION_STORAGE=file  # or 'redis' for production
# QB_SESSION_DIR=sessions/
